# ============================================
# GBP AUTOPILOT - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Google OAuth Credentials ---
# Get these from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
# For production on Railway: https://your-app.railway.app/auth/callback

# --- Google Gemini API Key ---
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# --- App Config ---
SESSION_SECRET=change_this_to_a_random_long_string_minimum_32_chars
PORT=3000

# --- Posting Schedule ---
# Days to post: 1=Mon, 3=Wed, 5=Fri (ISO weekday)
POST_DAYS=1,3,5
# Time to post (24hr, server timezone)
POST_HOUR=9
POST_MINUTE=0
